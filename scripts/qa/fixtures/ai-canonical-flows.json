  "verticals": {
    "ecommerce": {
      "heading": "E-commerce",
      "flows": [
        {
          "id": "EC-01",
          "scenario": "category",
          "prompt": "quero produtos para pele",
          "expect": {
            "visualBlock": true,
            "contentPattern": "Protetor|Hidratante|Solar|pele",
            "forbiddenPattern": null
          }
        },
        {
          "id": "EC-02",
          "scenario": "specific-entity",
          "prompt": "protetor solar facial",
          "expect": {
            "visualBlock": true,
            "contentPattern": "Protetor Solar",
            "forbiddenPattern": null
          }
        },
        {
          "id": "EC-03",
          "scenario": "recommendation",
          "prompt": "me ajuda com skincare facial",
          "expect": {
            "visualBlock": true,
            "contentPattern": "Protetor|Hidratante|Oleo|Creme",
            "forbiddenPattern": null
          }
        },
        {
          "id": "EC-04",
          "scenario": "contextual-follow-up",
          "skipAutomated": true,
          "skipReason": "Feed long-press hides composer (drawerOpen); covered in manual checklist B1",
          "setupPrompt": "protetor solar facial",
          "contextSourceId": "ecommerce-product-prod-5",
          "contextScope": "composer",
          "prompt": "o que combina com isso?",
          "expect": {
            "visualBlock": true,
            "contentPattern": "Protetor|Hidratante|Creme|Oleo",
            "forbiddenPattern": null
          }
        },
        {
          "id": "EC-05",
          "scenario": "fallback",
          "prompt": "qual o horario de funcionamento",
          "expect": {
            "visualBlock": false,
            "contentPattern": "Natura|ajudar|orientar",
            "forbiddenPattern": "Encontrei alguns produtos"
          }
        },
        {
          "id": "EC-06",
          "scenario": "drawer-linkage",
          "prompt": "protetor solar facial",
          "drawer": {
            "clickPattern": "Protetor Solar",
            "openPattern": "Adicionar|Comprar|Tamanho|Variante"
          }
        }
      ]
    },
